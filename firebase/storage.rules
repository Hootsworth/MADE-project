rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /eventCovers/{eventId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /eventWall/{eventId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn();
    }
  }
}
